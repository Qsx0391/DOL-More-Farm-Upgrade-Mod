:: Farm Sex Machine Widgets [widget]

<<widget "farm_machine_actions">>
    <<if $sexMachineTimer gt 0>>
        <<set $leftarm to "bound">>
        <<set $rightarm to "bound">>
    <<elseif $leftarm isnot 0>>
        <<arm_unbind>>
    <</if>>

	<<willpowerpain>>
	<<willpowerorgasm>>
	<<actioncarry>>
	<<actioncarrydrop>>

	<<combatstate>>
	<<carryblock>>
    
    <<if $orgasmdown gte 1 or ($pain gte 100 and $willpowerpain is 0)>>
        <<generateActionsMachine>>
    <<elseif $sexMachineTimer gt 0>>
        <span class="gold">你的左臂被无助地束缚着。</span>
        <br>
        <<if $leftactiondefault is "struggle" or $leftaction is "struggle">>
            <label><<radiobutton "$leftaction" "struggle" checked>><span class="red"> 挣扎</span> |</label>
            <label><<radiobutton "$leftaction" "rest">> 休息 |</label>
        <<else>>
            <label><<radiobutton "$leftaction" "struggle">><span class="red"> 挣扎</span> |</label>
            <label><<radiobutton "$leftaction" "rest" checked>> 休息 |</label>
        <</if>>
        <br>
        <span class="gold">你的右臂被无助地束缚着。</span>
        <br>
        <<if $rightactiondefault is "struggle" or $rightaction is "struggle">>
            <label><<radiobutton "$rightaction" "struggle" checked>><span class="red"> 挣扎</span> |</label>
            <label><<radiobutton "$rightaction" "rest">> 休息 |</label>
        <<else>>
            <label><<radiobutton "$rightaction" "struggle">><span class="red"> 挣扎</span> |</label>
            <label><<radiobutton "$rightaction" "rest" checked>> 休息 |</label>
        <</if>>
        <br>
    <<else>>
        <span class="gold">你的左臂是自由的。</span>
        <br>

        <<if $machine.speed lt 3>>
            <label><<radiobutton "$leftaction" "turn up">><span class="red"> 调大挡位</span> |</label>
        <</if>>
        <<if $machine.speed gt 1>>
            <label><<radiobutton "$leftaction" "turn down">><span class="green"> 调小挡位</span> |</label>
        <</if>>
        
        <<if $player.vaginaExist>>
            <<if $useClitVibrator>>
                <label><<radiobutton "$leftaction" "clit vibrator">><span class="purple"> 推开阴蒂的震动棒</span> |</label>
            <<else>>
                <label><<radiobutton "$leftaction" "clit vibrator">><span class="purple"> 把震动棒移向阴蒂</span> |</label>
            <</if>>
        <</if>>

        <<if $useNippleVibrator>>
            <label><<radiobutton "$leftaction" "nipple vibrator">><span class="purple"> 推开乳头的震动棒</span> |</label>
        <<else>>
            <label><<radiobutton "$leftaction" "nipple vibrator">><span class="purple"> 把震动棒移向乳头</span> |</label>
        <</if>>

        <label><<radiobutton "$leftaction" "rest" checked>> 休息 |</label>
        <br>

        <span class="gold">你的右臂是自由的。</span>
        <br>

        <<if $machine.speed lt 3>>
            <label><<radiobutton "$rightaction" "turn up">><span class="red"> 调大挡位</span> |</label>
        <</if>>
        <<if $machine.speed gt 1>>
            <label><<radiobutton "$rightaction" "turn down">><span class="green"> 调小挡位</span> |</label>
        <</if>>

        <<if $player.vaginaExist>>
            <<if $useClitVibrator>>
                <label><<radiobutton "$rightaction" "clit vibrator">><span class="purple"> 推开阴蒂的震动棒</span> |</label>
            <<else>>
                <label><<radiobutton "$rightaction" "clit vibrator">><span class="purple"> 把震动棒移向阴蒂</span> |</label>
            <</if>>
        <</if>>

        <<if $useNippleVibrator>>
            <label><<radiobutton "$rightaction" "nipple vibrator">><span class="purple"> 推开乳头的震动棒</span> |</label>
        <<else>>
            <label><<radiobutton "$rightaction" "nipple vibrator">><span class="purple"> 把震动棒移向乳头</span> |</label>
        <</if>>

        <label><<radiobutton "$rightaction" "rest" checked>> 休息 |</label>
    <</if>>
	<br><br>

	<<setupMidOrgasm>>
<</widget>>

<<widget "farm_sex_machine_unset">>
    <<unset $sexMachineGear>>
    <<unset $useClitVibrator>>
    <<unset $useNippleVibrator>>
    <<unset $useWhip>>
<</widget>>